{
  "name": "opensecure",
  "version": "1.0.0",
  "description": "OSS supply chain compromise visualizer",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "seed": "node dist/seed.js",
    "fetch": "node dist/fetch.js",
    "graph": "node dist/graph.js",
    "simulate": "node dist/simulate.js",
    "simulate:all": "node dist/simulate.js --all",
    "postinstall": "mkdir -p lib && cp node_modules/d3/dist/d3.min.js lib/d3.v7.min.js",
    "viz": "npx serve . -p 3000",
    "test": "node --test test/exposure-type.test.mjs test/simulate.test.mjs",
    "test:api": "node --test test/verify-api.test.mjs",
    "test:all": "node --test test/*.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "d3": "^7.9.0",
    "npm-high-impact": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
